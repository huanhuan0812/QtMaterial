#ifndef QTMATERIAL_CONFIG_H
#define QTMATERIAL_CONFIG_H

// QtMaterial 版本信息
#define QTMATERIAL_VERSION_MAJOR @PROJECT_VERSION_MAJOR@
#define QTMATERIAL_VERSION_MINOR @PROJECT_VERSION_MINOR@
#define QTMATERIAL_VERSION_PATCH @PROJECT_VERSION_PATCH@
#define QTMATERIAL_VERSION_STRING "@PROJECT_VERSION@"

// 构建配置
#cmakedefine QTMATERIAL_SHARED_LIB
#cmakedefine QTMATERIAL_STATIC_LIB

// 编译时特性
#cmakedefine QTMATERIAL_HAS_QT6

// 组件支持
#define QTMATERIAL_HAS_BUTTONS 1
#define QTMATERIAL_HAS_TOAST 1

#endif // QTMATERIAL_CONFIG_H